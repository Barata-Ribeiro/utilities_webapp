{
    "endOfLine": "lf",
    "semi": true,
    "singleQuote": true,
    "singleAttributePerLine": false,
    "tabWidth": 4,
    "printWidth": 120,
    "htmlWhitespaceSensitivity": "css",
    "plugins": ["prettier-plugin-tailwindcss"],
    "tailwindStylesheet": "app/app.css",
    "tailwindFunctions": ["clsx", "cn", "cva"],
    "overrides": [
        {
            "files": "**/*.yml",
            "options": {
                "tabWidth": 4
            }
        }
    ]
}
